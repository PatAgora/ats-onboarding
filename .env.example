# Copy to .env and fill values
FLASK_SECRET_KEY=change-this
DATABASE_URL=sqlite:///ats.db

# ---- Google Gemini AI (optional) ----
# Set this to enable AI candidate scoring and CV summarisation.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Signable (signable.co.uk) — get API key from Settings > API in your Signable dashboard
SIGNABLE_API_KEY=your_signable_api_key
SIGNABLE_BASE_URL=https://api.signable.co.uk/v1
SIGNABLE_WEBHOOK_SECRET=optional_webhook_signing_secret
SIGNABLE_TEMPLATE_FINGERPRINT=your_template_fingerprint_from_signable_dashboard

# Verifile pre-employment screening (verifile.co.uk)
# Get API key and Client ID from your Verifile account
VERIFILE_API_KEY=your_verifile_api_key
VERIFILE_BASE_URL=https://api.verifile.co.uk/v3
VERIFILE_CLIENT_ID=your_verifile_client_id
VERIFILE_WEBHOOK_SECRET=optional_webhook_signing_secret
# DBS level: Basic, Standard, or Enhanced (depends on client's Verifile package)
VERIFILE_DBS_LEVEL=Basic

# SMTP for onboarding emails & calendar invites
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=username
SMTP_PASS=password
SMTP_FROM="Talent Ops <talent@example.com>"

# Calendar invite defaults
INTERVIEWER_EMAIL=interviewer@example.com
TIMEZONE=Europe/London

# App base URL (public for webhooks & candidate links)
APP_BASE_URL=http://127.0.0.1:5000
